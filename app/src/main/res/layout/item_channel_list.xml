<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    style="@style/Widget.StreamTV.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <!-- Channel Logo -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_channel_logo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_channel_placeholder"
            app:shapeAppearanceOverlay="@style/CircleShape"
            android:scaleType="centerCrop"
            tools:src="@drawable/ic_channel_placeholder" />

        <!-- Channel Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="BBC World News" />

            <TextView
                android:id="@+id/tv_channel_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingTop="2dp"
                tools:text="News" />

        </LinearLayout>

        <!-- Live Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:text="LIVE"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/bg_live_badge"
            android:paddingHorizontal="6dp"
            android:gravity="center"
            android:layout_marginEnd="8dp" />

        <!-- Favorite Button -->
        <ImageButton
            android:id="@+id/btn_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_favorite_outline"
            android:contentDescription="Favorite"
            android:padding="6dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
